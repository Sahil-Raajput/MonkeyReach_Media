---
import "../styles/founder-card.css";
---

<section class="founder-section">

    <div class="container">

        <article class="founder-card">

            <div class="founder-image">

                <img
                    src="/logos/sahil-raajput-profile-photo.webp"
                    alt="Sahil Raajput"
                    loading="lazy"
                />

            </div>

            <div class="founder-content">

                <span class="founder-label">

                    Meet the Founder

                </span>

                <h2>

                    Helping Businesses Grow Smarter.

                </h2>

                <p>

                    I'm Sahil, founder of MonkeyReach.
                    I help businesses generate more leads,
                    increase sales and build sustainable
                    growth through performance marketing.

                </p>

                <div class="founder-bottom">

                    <div class="founder-social">

                        <a href="#" aria-label="LinkedIn">
                            in
                        </a>

                        <a href="#" aria-label="Instagram">
                            ◎
                        </a>

                        <a href="#" aria-label="YouTube">
                            ▶
                        </a>

                    </div>

                    <a
                        href="/contact"
                        class="founder-btn"
                    >

                        Let's Talk →

                    </a>

                </div>

            </div>

        </article>

    </div>

</section>