

---

const services = [

    {
        title: "Search Engine Optimization",
        description:
            "Improve your organic visibility, attract qualified visitors, and build sustainable growth through strategic SEO.",
        icon: "seo",
        link: "/services/seo"
    },

    {
        title: "Google Ads",
        description:
            "Reach customers actively searching for your products or services with targeted paid search campaigns.",
        icon: "ads",
        link: "/services/google-ads"
    },

    {
        title: "Meta Advertising",
        description:
            "Generate demand and reach new audiences through performance-focused Facebook and Instagram advertising.",
        icon: "meta",
        link: "/services/meta-ads"
    },

    {
        title: "Social Media Marketing",
        description:
            "Build brand awareness and engage your audience through consistent, strategic social media content.",
        icon: "social",
        link: "/services/social-media"
    }

];
---


<section class="services-grid">

    {services.map((service)=> (

        <article class="service-card">


            <div class="service-icon">


                {service.icon === "seo" && (

                    <svg viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="6"/>
                        <line x1="16" y1="16" x2="21" y2="21"/>
                        <path d="M11 8v6"/>
                        <path d="M8 11h6"/>
                    </svg>

                )}


                {service.icon === "ads" && (

                    <svg viewBox="0 0 24 24">
                        <path d="M4 13V9l12-4v14L4 15z"/>
                        <path d="M16 10h3a2 2 0 010 4h-3"/>
                        <line x1="7" y1="16" x2="8" y2="20"/>
                    </svg>

                )}


                {service.icon === "meta" && (

                    <svg viewBox="0 0 24 24">
                        <path d="M4 12c3-7 7-7 10 0s7 7 10 0"/>
                        <path d="M4 12c3 7 7 7 10 0s7-7 10 0"/>
                    </svg>

                )}


                {service.icon === "social" && (

                    <svg viewBox="0 0 24 24">
                        <circle cx="8" cy="10" r="3"/>
                        <circle cx="17" cy="8" r="2"/>
                        <path d="M3 20c0-3 3-5 5-5s5 2 5 5"/>
                        <path d="M15 14c3 0 5 2 6 5"/>
                    </svg>

                )}

            </div>


            <h3>
                {service.title}
            </h3>


            <p>
                {service.description}
            </p>


            <a href={service.link}>
                Learn More →
            </a>


        </article>

    ))}

</section>

<style>
/* ==========================================================
   SERVICES GRID
========================================================== */

.services-grid{

    width:100%;

    display:grid;

    grid-template-columns:repeat(4, 1fr);

    gap:24px;

    margin:60px auto;

}



/* ==========================================================
   CARD
========================================================== */

.service-card{

    display:flex;

    flex-direction:column;

    padding:30px;

    min-height:340px;

    background:#0d0d0d;

    border:1px solid rgba(255,255,255,.08);

    border-radius:20px;

    transition:.3s ease;

}



.service-card:hover{

    transform:translateY(-8px);

    border-color:#ff4d00;

    box-shadow:
    0 20px 40px rgba(0,0,0,.35);

}



/* ==========================================================
   ICON
========================================================== */


.service-icon{

    width:60px;

    height:60px;

    display:flex;

    align-items:center;

    justify-content:center;

    margin-bottom:24px;

    border-radius:16px;

    background:
    rgba(255,77,0,.12);

    border:1px solid rgba(255,77,0,.25);

}


.service-icon svg{

    width:28px;

    height:28px;

    stroke:#ff4d00;

    fill:none;

    stroke-width:2;

}



/* ==========================================================
   TEXT
========================================================== */


.service-card h3{

    font-size:1.25rem;

    margin-bottom:15px;

    line-height:1.3;

}


.service-card p{

    color:#a1a1aa;

    line-height:1.7;

    font-size:.95rem;

    flex-grow:1;

}


.service-card a{

    margin-top:25px;

    color:#ff4d00;

    font-weight:600;

}



/* ==========================================================
   RESPONSIVE
========================================================== */


@media(max-width:1100px){

    .services-grid{

        grid-template-columns:repeat(2,1fr);

    }

}



@media(max-width:650px){

    .services-grid{

        grid-template-columns:1fr;

    }

}

</style>