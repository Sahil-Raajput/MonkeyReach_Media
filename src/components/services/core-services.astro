---
const services = [
    {
        title: "Search Engine Optimization",
        description:
            "Improve your organic visibility, attract qualified visitors, and build sustainable growth through strategic SEO.",
        icon: "seo",
        link: "/services/seo",
    },

    {
        title: "Google Ads",
        description:
            "Reach customers actively searching for your products or services with targeted paid search campaigns.",
        icon: "ads",
        link: "/services/google-ads",
    },

    {
        title: "Meta Advertising",
        description:
            "Generate demand and reach new audiences through performance-focused Facebook and Instagram advertising.",
        icon: "meta",
        link: "/services/meta-ads",
    },

    {
        title: "Social Media Marketing",
        description:
            "Build brand awareness and engage your audience through consistent, strategic social media content.",
        icon: "social",
        link: "/services/social-media",
    },

    {
        title: "Digital Marketing",

        description:
            "A complete digital marketing solution that combines SEO, Google Ads, Meta Ads, social media marketing, content strategy, and conversion-focused execution to help your business grow faster.",

        icon: "marketing",

        link: "/services/digital-marketing",
    },
];
---

<section class="services-grid">
    {
        services.map((service) => (
            <article class="service-card">
                <div class="service-icon">
                    {service.icon === "seo" && (
                        <svg viewBox="0 0 24 24">
                            <circle cx="11" cy="11" r="6" />
                            <line x1="16" y1="16" x2="21" y2="21" />
                            <path d="M11 8v6" />
                            <path d="M8 11h6" />
                        </svg>
                    )}

                    {service.icon === "ads" && (
                        <svg viewBox="0 0 24 24">
                            <path d="M4 13V9l12-4v14L4 15z" />
                            <path d="M16 10h3a2 2 0 010 4h-3" />
                            <line x1="7" y1="16" x2="8" y2="20" />
                        </svg>
                    )}

                    {service.icon === "meta" && (
                        <svg viewBox="0 0 24 24">
                            <path d="M4 12c3-7 7-7 10 0s7 7 10 0" />
                            <path d="M4 12c3 7 7 7 10 0s7-7 10 0" />
                        </svg>
                    )}

                    {service.icon === "social" && (
                        <svg viewBox="0 0 24 24">
                            <circle cx="8" cy="10" r="3" />
                            <circle cx="17" cy="8" r="2" />
                            <path d="M3 20c0-3 3-5 5-5s5 2 5 5" />
                            <path d="M15 14c3 0 5 2 6 5" />
                        </svg>
                    )}

                    {service.icon === "marketing" && (
                        <svg viewBox="0 0 24 24">
                            <path d="M4 19V9" />

                            <path d="M10 19V5" />

                            <path d="M16 19V12" />

                            <path d="M22 19V3" />
                        </svg>
                    )}
                </div>

                <h3>{service.title}</h3>

                <p>{service.description}</p>

                <a href={service.link}>Learn More →</a>
            </article>
        ))
    }
</section>

<style>
    /* ==========================================================
   SERVICES GRID
========================================================== */

    .services-grid {
        width: min(100%, 1180px);

        margin: var(--space-4) auto 0;

        padding-inline: clamp(1rem, 4vw, 2rem);

        display: grid;

        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));

        gap: clamp(1.25rem, 2vw, 2rem);
    }

    /* ==========================================================
   CARD
========================================================== */

    .service-card {
        display: flex;

        flex-direction: column;

        height: 100%;

        padding: clamp(1.75rem, 2vw, 2rem);

        background: var(--color-surface);

        border: var(--border-default);

        border-radius: var(--radius-lg);

        transition:
            transform var(--transition-normal),
            border-color var(--transition-normal),
            box-shadow var(--transition-normal);
    }

    .service-card:hover {
        transform: translateY(-6px);

        border-color: rgba(255, 77, 0, 0.45);

        box-shadow: var(--shadow-soft);
    }

    /* ==========================================================
   ICON
========================================================== */

    .service-icon {
        width: 64px;

        height: 64px;

        display: flex;

        align-items: center;

        justify-content: center;

        margin-bottom: var(--space-5);

        border-radius: 18px;

        background: rgba(255, 77, 0, 0.1);

        border: 1px solid rgba(255, 77, 0, 0.2);
    }

    .service-icon svg {
        width: 30px;

        height: 30px;

        stroke: var(--color-primary);

        fill: none;

        stroke-width: 2;

        stroke-linecap: round;

        stroke-linejoin: round;
    }

    /* ==========================================================
   TEXT
========================================================== */

    .service-card h3 {
        margin-bottom: var(--space-4);

        font-size: 1.35rem;

        line-height: 1.25;
    }

    .service-card p {
        flex: 1;

        margin-bottom: var(--space-6);

        color: var(--color-text-muted);

        line-height: 1.8;
    }

    .service-card a {
        display: inline-flex;

        align-items: center;

        gap: 0.4rem;

        margin-top: auto;

        color: var(--color-primary);

        font-weight: 600;

        transition: gap var(--transition-fast);
    }

    .service-card:hover a {
        gap: 0.7rem;
    }

    /* ==========================================================
   TABLET
========================================================== */

    .service-card:last-child {
        grid-column: span 2;
    }

    @media (max-width: 992px) {
        .services-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    /* ==========================================================
   MOBILE
========================================================== */

    @media (max-width: 640px) {
        .services-grid {
            grid-template-columns: 1fr;

            padding-inline: 0;
        }
        .service-card:last-child {
            grid-column: auto;
        }
    }
</style>
