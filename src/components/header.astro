---
import "../styles/header.css";
---

<header class="site-header">

    <div class="container header-inner">

        <a href="/" class="logo">
            Monkey<span>Reach</span>
        </a>

        <nav
            class="nav"
            aria-label="Primary Navigation"
        >

            <a href="#">Services</a>
            <a href="#">Industries</a>
            <a href="#">Case Studies</a>
            <a href="#">Resources</a>
            <a href="#">Contact</a>

        </nav>

        <div class="header-actions">

            <a
                href="/login"
                class="login-btn"
            >
                Login
            </a>

            <a
                href="/contact"
                class="cta-btn"
            >
                Get Started
            </a>

            <button
                class="menu-btn"
                type="button"
                aria-label="Toggle Navigation"
                aria-expanded="false"
                aria-controls="primary-navigation"
            >

                <span></span>
                <span></span>
                <span></span>

            </button>

        </div>

    </div>

</header>

<script>
    import "../scripts/header.js";
</script>