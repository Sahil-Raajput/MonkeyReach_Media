---
import "../styles/header.css";
import { URLS } from "../data/urls";
---

<header class="site-header">

    <div class="container header-inner">


        <a 
            href={URLS.pages.home} 
            class="logo"
        >

            <img
                src={URLS.assets.logo}
                alt="MonkeyReach Digital Marketing Agency"
                width="220"
                height="56"
            />

        </a>





        <nav
            class="nav"
            id="primary-navigation"
            aria-label="Primary Navigation"
        >


            <a href={URLS.pages.home}>
                Home
            </a>



            <a href={URLS.pages.services}>
                Services
            </a>



            <a href={URLS.pages.about}>
                About Us
            </a>



            <a href={URLS.pages.contact}>
                Contact
            </a>


        </nav>







        <div class="header-actions">



            <a
                href={URLS.pages.login}
                class="login-btn"
            >
                Login
            </a>





            <a
                href={URLS.pages.contact}
                class="cta-btn"
            >
                Get Started
            </a>





            <button
                class="menu-btn"
                type="button"
                aria-label="Toggle Navigation"
                aria-expanded="false"
                aria-controls="primary-navigation"
            >

                <span></span>

                <span></span>

                <span></span>

            </button>



        </div>



    </div>


</header>





<script>
    import "../scripts/header.js";
</script>