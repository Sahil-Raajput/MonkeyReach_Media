---
import "../styles/header.css";
---

<header class="site-header">

    <div class="container header-inner">

        <a href="/" class="logo">

            <img
                src="/logos/MonkeyReach-Logo.avif"
                alt="MonkeyReach"
                width="220"
                height="56"
            />

        </a>

        <nav
            class="nav"
            id="primary-navigation"
            aria-label="Primary Navigation"
        >
            <a href="/">Home</a>
            <a href="/services">Services</a>
            <a href="/industry">By Industries</a>
            <a href="/locations">By Locations</a>
            <a href="/about">About Us</a>
            <a href="/contact">Contact</a>

        </nav>

        <div class="header-actions">

            <a
                href="/login"
                class="login-btn"
            >
                Login
            </a>

            <a
                href="/contact"
                class="cta-btn"
            >
                Get Started
            </a>

            <button
                class="menu-btn"
                type="button"
                aria-label="Toggle Navigation"
                aria-expanded="false"
                aria-controls="primary-navigation"
            >

                <span></span>
                <span></span>
                <span></span>

            </button>

        </div>

    </div>

</header>

<script>
    import "../scripts/header.js";
</script>