---
import "../styles/hero.css";
---

<section class="hero">
    <div class="container hero-grid">
        <div class="hero-content">
            <span class="hero-badge"> ROI Focused Marketing Company </span>

            <h1>
                Turn Your Website Into
                <span> A Client Generating Machine.</span>
            </h1>

            <p>
                MonkeyReach helps businesses generate qualified leads through
                SEO, Google Ads, Local SEO, and high-converting websites. Less
                guesswork. More enquiries. Predictable growth.
            </p>

            <div class="hero-actions">
                <a href="https://wa.me/919053556090" class="btn btn-primary">
                    Book Free Strategy Call
                </a>

                <a href="#services" class="btn btn-secondary">
                    Explore Services
                </a>
            </div>

            <div class="hero-stats">
                <div>
                    <h3>150+</h3>
                    <span>Businesses Served</span>
                </div>

                <div>
                    <h3>4.9★</h3>
                    <span>Client Rating</span>
                </div>

                <div>
                    <h3>300%</h3>
                    <span>Average Growth</span>
                </div>
            </div>
        </div>

        <div class="hero-card">
            <div class="card">
                <div class="metric">
                    <span>Organic Traffic</span>

                    <strong>+214%</strong>
                </div>

                <div class="graph">
                    <div class="bar h1"></div>
                    <div class="bar h2"></div>
                    <div class="bar h3"></div>
                    <div class="bar h4"></div>
                    <div class="bar h5"></div>
                    <div class="bar h6"></div>
                </div>

                <div class="mini-cards">
                    <div>
                        <small>Leads</small>
                        <h4>82</h4>
                    </div>

                    <div>
                        <small>Conversion</small>
                        <h4>7.8%</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
