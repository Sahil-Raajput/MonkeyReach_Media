---
import "../styles/footer.css";

import { URLS } from "../data/urls";
import { ASSETS } from "../data/assets";
import { SITE } from "../data/site";
---


<footer class="footer">

    <div class="container footer-content">


        <div class="footer-brand">


            <a 
                href={URLS.pages.home} 
                class="footer-logo"
            >

                <img 
                    src={ASSETS.logo}
                    alt="MonkeyReach Digital Marketing Agency Logo"
                />

            </a>





            <p class="footer-description">

                MonkeyReach helps businesses grow through SEO, Google Ads, Meta Ads, Local SEO, website development, and performance-driven digital marketing strategies.

            </p>


        </div>







        <nav class="footer-nav">



            <a href={URLS.legal.refund}>
                Refund & Cancellation Policy
            </a>




            <a href={URLS.legal.terms}>
                Terms & Conditions
            </a>




            <a href={URLS.legal.cookie}>
                Cookie Policy
            </a>




            <a href={URLS.legal.privacy}>
                Privacy Policy
            </a>




            <a href={URLS.legal.editorial}>
                Editorial Policy
            </a>




            <a href={URLS.legal.disclaimer}>
                Disclaimer
            </a>



        </nav>







        <p class="footer-copy">

            © {new Date().getFullYear()} {SITE.name}. All rights reserved.

        </p>






    </div>


</footer>