---
import Layout from "../layouts/Layout.astro";
import "../styles/contact.css";
---

<Layout>

<section class="contact-hero">

    <div class="container">

        <span class="page-eyebrow">
            Contact
        </span>

        <h1 class="page-title">
            Let's Talk About Growing Your Business
        </h1>

        <p class="page-description">

            Whether you're looking to improve your search visibility, generate qualified leads, redesign your website, or explore digital marketing opportunities, we'd love to learn more about your business and discuss how MonkeyReach can help.

        </p>

    </div>

</section>



<section class="contact-main">

    <div class="container">

        <div class="contact-grid">


            <!-- Contact Information -->

            <aside class="contact-info">

                <h2>
                    Get in Touch
                </h2>

                <p>

                    Have a project in mind? Tell us about your business, your goals, and your budget. We'll review your requirements and recommend the most suitable next steps.

                </p>


                <div class="contact-card">

                    <h3>
                        WhatsApp
                    </h3>

                    <a href="https://wa.me/919053556090">
                        +91 90535 56090
                    </a>

                </div>



                <div class="contact-card">

                    <h3>
                        Email
                    </h3>

                    <a href="mailto:contact@monkeyreach.com">
                        contact@monkeyreach.com
                    </a>

                </div>



                <div class="contact-card">

                    <h3>
                        Location
                    </h3>

                    <p>
                        Kurukshetra, Haryana, India
                    </p>

                </div>



                <div class="contact-card">

                    <h3>
                        Working Hours
                    </h3>

                    <p>
                        Monday – Sunday
                        <br />
                        9:00 AM – 9:00 PM (IST)
                    </p>

                </div>


                <div class="contact-note">

                    We typically respond within one business day.

                </div>

            </aside>





            <!-- Contact Form -->

            <div class="contact-form-wrapper">

                <h2>
                    Tell Us About Your Project
                </h2>

                <p>

                    Share a few details about your business and objectives. We'll review your enquiry and get back to you shortly.

                </p>

                <form class="contact-form">

                    <div class="form-group">

                        <label for="budget">
                            Estimated Budget
                        </label>

                        <select id="budget">

                            <option>Select your budget</option>
                            <option>Under ₹25,000</option>
                            <option>₹25,000 – ₹50,000</option>
                            <option>₹50,000 – ₹1,00,000</option>
                            <option>₹1,00,000+</option>

                        </select>

                    </div>



                    <div class="form-row">

                        <div class="form-group">

                            <label for="name">
                                Your Name
                            </label>

                            <input
                                type="text"
                                id="name"
                                placeholder="John Smith"
                            />

                        </div>



                        <div class="form-group">

                            <label for="email">
                                Email Address
                            </label>

                            <input
                                type="email"
                                id="email"
                                placeholder="john@example.com"
                            />

                        </div>

                    </div>



                    <div class="form-row">

                        <div class="form-group">

                            <label for="company">
                                Company Name
                            </label>

                            <input
                                type="text"
                                id="company"
                            />

                        </div>



                        <div class="form-group">

                            <label for="phone">
                                Phone Number
                            </label>

                            <input
                                type="tel"
                                id="phone"
                            />

                        </div>

                    </div>



                    <div class="form-group">

                        <label for="message">
                            Project Details
                        </label>

                        <textarea
                            id="message"
                            rows="7"
                            placeholder="Tell us about your business, goals, challenges, and what you're looking to achieve."
                        ></textarea>

                    </div>



                    <button
                        type="submit"
                        class="submit-btn"
                    >

                        Send Message

                    </button>


                    <p class="form-disclaimer">

                        By submitting this form, you agree to our
                        <a href="/privacy-policy">
                            Privacy Policy
                        </a>.

                    </p>

                </form>

            </div>

        </div>

    </div>

</section>





<section class="location-section">

    <div class="container">

        <div class="location-content">

            <h2>
                Serving Clients Across India & Worldwide
            </h2>

            <p>

                MonkeyReach is based in Kurukshetra, Haryana. While we're happy to meet locally when required, most consultations and project discussions take place online via Google Meet, Zoom, or Microsoft Teams.

            </p>

            <a
                href="https://maps.google.com"
                target="_blank"
                class="location-btn"
            >

                View on Google Maps

            </a>

        </div>

    </div>

</section>





<section class="contact-options">

    <div class="container">

        <div class="section-heading">

            <span class="page-eyebrow">
                More Ways to Connect
            </span>

            <h2>
                Other Reasons to Reach Out
            </h2>

        </div>


        <div class="options-grid">


            <article class="option-card">

                <h3>
                    General Enquiries
                </h3>

                <p>

                    Questions about our services, pricing, or process? We'd be happy to help.

                </p>

                <a href="/contact">
                    Contact Us →
                </a>

            </article>




            <article class="option-card">

                <h3>
                    Partnerships
                </h3>

                <p>

                    Interested in referral partnerships, white-label SEO, or collaborative marketing opportunities?

                </p>

                <a href="mailto:contact@monkeyreach.com">
                    Email Us →
                </a>

            </article>




            <article class="option-card">

                <h3>
                    Careers
                </h3>

                <p>

                    Passionate about SEO, content, paid advertising, or web development? We'd love to hear from you.

                </p>

                <a href="mailto:contact@monkeyreach.com">
                    Join Our Team →
                </a>

            </article>


        </div>

    </div>

</section>





<section class="contact-cta">

    <div class="container">

        <div class="cta-box">

            <h2>

                Ready to Grow Online?

            </h2>

            <p>

                Every successful marketing strategy starts with a conversation. Tell us about your business and we'll recommend practical next steps based on your goals—not a generic sales pitch.

            </p>

            <a
                href="#"
                class="cta-btn"
            >

                Start the Conversation

            </a>

        </div>

    </div>

</section>

</Layout>