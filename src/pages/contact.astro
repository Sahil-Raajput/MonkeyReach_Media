---
import Layout from "../layouts/Layout.astro";
import "../styles/contact.css";
---

<Layout>

<section class="contact-hero">

    <div class="container">

        <span class="page-eyebrow">
            Contact
        </span>

        <h1 class="page-title">
            Let's Talk About Growing Your Business
        </h1>

        <p class="page-description">

            Whether you need better search visibility, more qualified leads,
            a stronger online presence, or a complete digital marketing strategy,
            MonkeyReach is here to help your business grow.

        </p>

    </div>

</section>




<section class="contact-main">

    <div class="container">

        <div class="contact-grid">


            <!-- Contact Information -->

            <aside class="contact-info">


                <h2>
                    Get in Touch
                </h2>


                <p>

                    Have a project in mind? Reach out directly and tell us about
                    your business goals. We'll discuss practical strategies
                    tailored to your needs.

                </p>



                <div class="contact-card">

                    <h3>
                        WhatsApp
                    </h3>

                    <a href="https://wa.me/919053556090">

                        +91 90535 56090

                    </a>

                </div>




                <div class="contact-card">

                    <h3>
                        Email
                    </h3>

                    <a href="mailto:thesahilraajput@gmail.com">

                        thesahilraajput@gmail.com

                    </a>

                </div>




                <div class="contact-card">

                    <h3>
                        Location
                    </h3>

                    <p>
                        Kurukshetra, Haryana, India
                    </p>

                </div>




                <div class="contact-card">

                    <h3>
                        Working Hours
                    </h3>

                    <p>
                        Monday – Sunday
                        <br />
                        9:00 AM – 9:00 PM (IST)
                    </p>

                </div>



                <div class="contact-note">

                    We usually respond within one business day.

                </div>


            </aside>







            <!-- Direct Contact -->

            <div class="contact-form-wrapper">


                <h2>
                    Start a Conversation
                </h2>


                <p>

                    Instead of filling out long forms, contact us directly.
                    Share your business challenges, goals, and requirements,
                    and we'll guide you toward the right digital strategy.

                </p>




                <div class="direct-contact">


                    <div class="contact-card">

                        <h3>
                            Talk on WhatsApp
                        </h3>


                        <a href="https://wa.me/919053556090">

                            Message Us →

                        </a>


                    </div>




                    <div class="contact-card">

                        <h3>
                            Send an Email
                        </h3>


                        <a href="mailto:thesahilraajput@gmail.com">

                            Email Us →

                        </a>


                    </div>



                </div>





                <a
                    href="https://wa.me/919053556090"
                    class="submit-btn"
                >

                    Start WhatsApp Chat

                </a>



            </div>


        </div>

    </div>

</section>







<section class="location-section">

    <div class="container">

        <div class="location-content">


            <h2>
                Serving Clients Across India & Worldwide
            </h2>



            <p>

                MonkeyReach is based in Kurukshetra, Haryana.
                We work with businesses across India and worldwide through
                online consultations using Google Meet, Zoom, and Microsoft Teams.

            </p>




            <a
                href="https://share.google/hS1ejnyTogqFTG95q"
                target="_blank"
                class="location-btn"
            >

                View on Google Maps

            </a>


        </div>


    </div>


</section>








<section class="contact-options">

    <div class="container">


        <div class="section-heading">


            <span class="page-eyebrow">

                More Ways to Connect

            </span>



            <h2>

                Other Reasons to Reach Out

            </h2>


        </div>





        <div class="options-grid">



            <article class="option-card">


                <h3>
                    General Enquiries
                </h3>


                <p>

                    Questions about our services, pricing, or digital marketing
                    process? We're happy to help.

                </p>



                <a href="/contact">

                    Contact Us →

                </a>


            </article>







            <article class="option-card">


                <h3>
                    Partnerships
                </h3>


                <p>

                    Interested in referral partnerships, white-label SEO,
                    or collaboration opportunities?

                </p>



                <a href="mailto:thesahilraajput@gmail.com">

                    Email Us →

                </a>


            </article>







            <article class="option-card">


                <h3>
                    Careers
                </h3>


                <p>

                    Passionate about SEO, content marketing, paid ads,
                    or web development?

                </p>



                <a href="mailto:thesahilraajput@gmail.com">

                    Join Our Team →

                </a>


            </article>




        </div>


    </div>


</section>







<section class="contact-cta">


    <div class="container">


        <div class="cta-box">


            <h2>

                Ready to Grow Online?

            </h2>



            <p>

                Every successful marketing strategy starts with a conversation.
                Tell us about your business and we'll suggest practical next
                steps based on your goals.

            </p>




            <a
                href="https://wa.me/919053556090"
                class="cta-btn"
            >

                Start the Conversation

            </a>



        </div>


    </div>


</section>

</Layout>